# Obwocha's Pharmacy — Payment Backend
# Copy this to .env and fill in your keys

# === STRIPE (Test Mode) ===
# Get keys at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# === M-Pesa Daraja (Safaricom Sandbox) ===
# Register at: https://developer.safaricom.co.ke
# Create an app → get Consumer Key & Consumer Secret
# Also get your Paybill/Till number and passkey
MPESA_CONSUMER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MPESA_CONSUMER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MPESA_PASSKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MPESA_SHORTCODE=174379
MPESA_TILL_NUMBER=xxxxxx

# === Server ===
PORT=3001
FRONTEND_URL=http://localhost:8000
